# ==================== ENVIRONMENT CONFIGURATION TEMPLATE ====================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!
# The .env file is listed in .gitignore for your safety

# ==================== MongoDB Configuration ====================
# Your MongoDB connection string
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017

# ==================== Server Configuration ====================
# Server port (default: 5000)
PORT=5000

# Node environment (development, production, etc.)
NODE_ENV=development

# ==================== Database Configuration ====================
# MongoDB database name
DB_NAME=content_calendar

# MongoDB collection name for posts
COLLECTION_NAME=posts

# ==================== Authentication Configuration ====================
# Admin login email
# Change this to your desired admin email
LOGIN_EMAIL=your-email@example.com

# Admin login password
# Change this to a strong, secure password
# Example: P@ssw0rd2026!SecurePassword
LOGIN_PASSWORD=your-secure-password

# ==================== Session Configuration ====================
# Secret key for encrypting session data
# Generate a random string: use 'openssl rand -hex 32' or similar
# This MUST be unique and kept secret
SESSION_SECRET=your-random-secret-key-here

# ==================== IMPORTANT SECURITY NOTES ====================
# 1. NEVER commit this file to git (already in .gitignore)
# 2. Always use strong passwords
# 3. Generate random SESSION_SECRET for each environment
# 4. Use different credentials for development and production
# 5. Rotate credentials periodically
# 6. Never share your .env file via email or chat
# 7. Keep MongoDB connection strings secret

# ==================== SETUP INSTRUCTIONS ====================
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Never commit .env to version control
# 4. Verify .gitignore includes .env

